# Browser Run CDP credentials for local Vitest Browser Mode runs.
# Keep real values in .env; this example file is safe to commit.
CLOUDFLARE_ACCOUNT_ID="<account-id>"
CLOUDFLARE_API_TOKEN="<token-with-browser-rendering-edit>"

# The parallelism example defaults to 8. Lower this when debugging or when your
# account/environment needs a smaller browser worker pool.
CLOUDFLARE_BROWSER_RUN_CONCURRENCY="8"

# Benchmarks use the same per-browser session cap across local and Browser Run modes.
# Multi-browser Browser Run mode multiplies this by CLOUDFLARE_BROWSER_RUN_MAX_BROWSERS.
BENCHMARK_CONCURRENCY="4"
BENCHMARK_APP_LATENCY_MS="1000"
CLOUDFLARE_BROWSER_RUN_MAX_BROWSERS="4"
CLOUDFLARE_BROWSER_RUN_ACQUIRE_INTERVAL_MS="1000"

# Optional larger benchmark profiles: default, full, large, xlarge, stress.
# BENCHMARK_SCENARIO_COUNT overrides the selected profile size.
# BENCHMARK_PROFILE="large"
# BENCHMARK_SCENARIO_COUNT="384"
