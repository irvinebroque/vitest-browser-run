# Browser Run CDP credentials for local Vitest Browser Mode runs.
# Keep real values in .env; this example file is safe to commit.
CLOUDFLARE_ACCOUNT_ID="<account-id>"
CLOUDFLARE_API_TOKEN="<token-with-browser-rendering-edit>"

# The parallelism example defaults to 8. Lower this when debugging or when your
# account/environment needs a smaller browser worker pool.
CLOUDFLARE_BROWSER_RUN_CONCURRENCY="8"
