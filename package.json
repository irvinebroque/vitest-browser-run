{
	"name": "vitest-browser-run-workspace",
	"version": "0.0.0",
	"private": true,
	"type": "module",
	"packageManager": "pnpm@10.26.1",
	"scripts": {
		"build:provider": "pnpm --filter @cloudflare/vitest-browser-run-provider build",
		"build:example": "pnpm --filter @vitest-browser-run/parallelism-example build",
		"dev": "pnpm --filter @vitest-browser-run/parallelism-example dev",
		"start": "pnpm dev",
		"test": "pnpm --filter @cloudflare/vitest-browser-run-provider test",
		"test:browser-run": "pnpm --filter @vitest-browser-run/parallelism-example test:browser-run",
		"test:browser-run:parallel": "pnpm --filter @vitest-browser-run/parallelism-example test:browser-run:parallel",
		"test:browser-run:visual": "pnpm --filter @vitest-browser-run/parallelism-example test:browser-run:visual",
		"test:browser-run:visual:update": "pnpm --filter @vitest-browser-run/parallelism-example test:browser-run:visual:update",
		"typecheck": "pnpm --filter @cloudflare/vitest-browser-run-provider typecheck && pnpm --filter @vitest-browser-run/parallelism-example typecheck",
		"cf-typegen": "pnpm --filter @vitest-browser-run/parallelism-example cf-typegen"
	},
	"devDependencies": {
		"vite": "8.1.2"
	}
}
