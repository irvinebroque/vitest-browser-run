{
	"name": "vitest-browser-run",
	"version": "0.0.0",
	"private": true,
	"type": "module",
	"scripts": {
		"build": "vite build",
		"deploy": "npm run build && wrangler deploy",
		"dev": "vite dev",
		"preview": "npm run build && vite preview",
		"start": "vite dev",
		"test": "vitest run --config vitest.config.ts",
		"test:browser-run": "vitest run --config vitest.browser-run.config.ts",
		"test:browser-run:visual": "vitest run --config vitest.browser-run.config.ts test/browser/visual-*.browser.test.ts",
		"test:browser-run:visual:update": "vitest run --config vitest.browser-run.config.ts test/browser/visual-*.browser.test.ts --update",
		"ci:browser-run:visual": "node scripts/run-browser-run-visual.mjs",
		"benchmark:browser-run": "node scripts/benchmark-browser-run.mjs",
		"test:watch": "vitest --config vitest.config.ts",
		"cf-typegen": "wrangler types"
	},
	"devDependencies": {
		"@cloudflare/vite-plugin": "^1.42.4",
		"@cloudflare/vitest-pool-workers": "^0.17.0",
		"@types/node": "^26.1.0",
		"@vitest/browser": "^4.1.9",
		"playwright-core": "^1.61.1",
		"typescript": "^5.5.2",
		"vite": "^8.1.2",
		"vitest": "^4.1.9",
		"wrangler": "^4.106.0"
	}
}
