{
	"compilerOptions": {
		"target": "es2024",
		"lib": ["es2024", "dom", "dom.iterable"],
		"module": "es2022",
		"moduleResolution": "Bundler",
		"rootDir": "src",
		"outDir": "dist",
		"declaration": true,
		"declarationMap": true,
		"isolatedModules": true,
		"allowSyntheticDefaultImports": true,
		"forceConsistentCasingInFileNames": true,
		"strict": true,
		"skipLibCheck": true,
		"types": ["node"]
	},
	"include": ["src/**/*.ts"],
	"exclude": ["dist"]
}
