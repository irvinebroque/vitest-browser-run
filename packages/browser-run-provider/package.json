{
	"name": "@cloudflare/vitest-browser-run-provider",
	"version": "0.0.0",
	"type": "module",
	"description": "Cloudflare Browser Run provider for Vitest Browser Mode with pooled Playwright CDP sessions",
	"sideEffects": false,
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js"
		},
		"./package.json": "./package.json"
	},
	"main": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"files": [
		"dist"
	],
	"scripts": {
		"build": "tsc --project tsconfig.json",
		"test": "vitest run --config vitest.config.ts",
		"typecheck": "tsc --noEmit --project tsconfig.json && tsc --noEmit --project test/tsconfig.json"
	},
	"peerDependencies": {
		"@vitest/browser-playwright": "^5.0.0-beta.5",
		"playwright": "*",
		"vitest": "^5.0.0-beta.5"
	},
	"devDependencies": {
		"@types/node": "26.1.0",
		"@vitest/browser-playwright": "link:../../../vitest/packages/browser-playwright",
		"playwright": "npm:playwright-core@1.61.1",
		"typescript": "5.9.3",
		"vite": "8.1.2",
		"vitest": "link:../../../vitest/packages/vitest"
	}
}
